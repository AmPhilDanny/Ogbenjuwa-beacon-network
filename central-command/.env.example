# Server
PORT=4001
NODE_ENV=development

# Database (Supabase / production Postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ogbenjuwa_central

# Redis (optional — app runs without it)
REDIS_URL=redis://localhost:6379

# JWT — change these in production!
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — add your Vercel deployment domain here (comma-separated)
#   e.g. CORS_ORIGINS=http://localhost:4000,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:4000,http://localhost:3000,http://localhost:3001
