{
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "outputDirectory": "admin/dist",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null
}
